# Copy this file to .env and fill in your real keys

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDERS (at least ONE required - system will auto-fallback through all)
# ═══════════════════════════════════════════════════════════════════════════

# NVIDIA NIM API (RECOMMENDED - generous free tier: 1000 requests/day)
# Get key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Google Gemini API (generous free tier)
# Get key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (fast but limited: 100k tokens/day on free tier)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Together.ai (good free tier option)
# Get key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter (aggregates many providers, pay-as-you-go)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ═══════════════════════════════════════════════════════════════════════════
# SEARCH PROVIDERS (at least ONE required)
# ═══════════════════════════════════════════════════════════════════════════

# Tavily Search API — primary (recommended, get free key at app.tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Google Custom Search — fallback (optional if Tavily is set)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Media Analysis (Deepfake / Image moderation)
# ═══════════════════════════════════════════════════════════════════════════

# Sightengine API (free tier available)
# Get keys at: https://sightengine.com/
SIGHTENGINE_API_USER=your_sightengine_api_user_here
SIGHTENGINE_API_SECRET=your_sightengine_api_secret_here

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Tracing & Debugging
# ═══════════════════════════════════════════════════════════════════════════

# LangSmith tracing (optional — leave blank to disable)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=fact-verification
