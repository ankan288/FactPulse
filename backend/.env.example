# Copy this file to .env and fill in your real keys

# Google Gemini API (required unless using Groq)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (fallback if Gemini is not set)
GROQ_API_KEY=your_groq_api_key_here

# Tavily Search API — primary (recommended, get free key at app.tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Google Custom Search — fallback (optional if Tavily is set)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# LangSmith tracing (optional — leave blank to disable)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=fact-verification
